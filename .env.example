# ─────────────────────────────────────────────
# 後端機密（apps/api）放在 Cloudflare Workers Secrets，
# 本地開發放在 apps/api/.dev.vars（已被 gitignore）。
# 下面僅列出需要配置的 key，便於開源用戶照抄。
# ─────────────────────────────────────────────

# JWT 簽名密鑰（Phase 1 啟用）
# JWT_SECRET=
# JWT_REFRESH_SECRET=

# 郵件（可選，Phase 5；不配置則靜默跳過發信）
# RESEND_API_KEY=
# MAIL_FROM=noreply@example.com

# ─────────────────────────────────────────────
# 前端構建變量（apps/web，Phase 6）
# ─────────────────────────────────────────────
# VITE_API_BASE_URL=http://localhost:8787
